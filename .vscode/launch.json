{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: HTTP Server",
            "type": "debugpy",
            "request": "launch",
            "module": "app.main",
            "args": [
                "--http"
            ],
            "justMyCode": true,
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/.venv/bin/python"
        },
        {
            "name": "Python: All Workers",
            "type": "debugpy",
            "request": "launch",
            "module": "app.main",
            "args": [
                "--workers"
            ],
            "justMyCode": true,
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/.venv/bin/python"
        },
        {
            "name": "Python: Channel Inbound Worker",
            "type": "debugpy",
            "request": "launch",
            "module": "app.main",
            "args": [
                "--workers",
                "channel_inbound"
            ],
            "justMyCode": true,
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/.venv/bin/python"
        },
        {
            "name": "Python: Cognition Response Worker",
            "type": "debugpy",
            "request": "launch",
            "module": "app.main",
            "args": [
                "--workers",
                "cognition_response"
            ],
            "justMyCode": true,
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/.venv/bin/python"
        }
    ]
}