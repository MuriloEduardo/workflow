{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: All Workers",
            "type": "debugpy",
            "request": "launch",
            "module": "app.main",
            "justMyCode": true,
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/.venv/bin/python"
        },
        {
            "name": "Python: Channel Inbound Worker",
            "type": "debugpy",
            "request": "launch",
            "module": "app.main",
            "args": [
                "--workers",
                "channel_inbound"
            ],
            "justMyCode": true,
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/.venv/bin/python"
        },
        {
            "name": "Python: Cognition Response Worker",
            "type": "debugpy",
            "request": "launch",
            "module": "app.main",
            "args": [
                "--workers",
                "cognition_response"
            ],
            "justMyCode": true,
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/.venv/bin/python"
        }
    ]
}